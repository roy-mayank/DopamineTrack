{
  "manifest_version": 3,
  "name": "YT Time Tracker",
  "version": "3.0",
  "permissions": ["storage", "alarms", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*", "*://*.123series.stream/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}
